# Flask runtime
TH4DER_DEBUG=0
TH4DER_HOST=127.0.0.1
TH4DER_PORT=8000

# Security
TH4DER_JWT_SECRET=change_me_to_long_random_secret
TH4DER_JWT_EXPIRES_HOURS=72

# Database
# SQLite local fallback example:
# TH4DER_DATABASE_URL=sqlite:///./th4der.db
#
# PostgreSQL production example:
# TH4DER_DATABASE_URL=postgresql+psycopg://th4der:password@127.0.0.1:5432/th4der
TH4DER_DATABASE_URL=postgresql+psycopg://th4der:password@127.0.0.1:5432/th4der

# WebRTC optional TURN
TH4DER_RTC_TURN_URL=
TH4DER_RTC_TURN_USERNAME=
TH4DER_RTC_TURN_CREDENTIAL=
TH4DER_RTC_ICE_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Limits
TH4DER_MAX_MESSAGE_IMAGE_BYTES=5242880
TH4DER_MAX_MESSAGE_FILE_BYTES=15728640

# Logging
TH4DER_CALL_DEBUG_LOGGING=0

