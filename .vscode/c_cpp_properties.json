      "browse": {
        "path": [
          "${workspaceFolder}",
          "C:/flutter/bin/cache/artifacts/engine/windows-x64/cpp_client_wrapper/include",
          "C:/flutter/bin/cache/artifacts/engine/linux-x64"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
